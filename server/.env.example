# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/taskflow

# JWT
JWT_SECRET=your_super_secret_min_32_characters_here_change_this
JWT_EXPIRES_IN=7d

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_from_aistudio_google_com

# Frontend URL (for CORS + reset email links)
CLIENT_URL=http://localhost:5173

# Email / SMTP (optional — OTP prints to console if not set)
# Gmail: enable 2FA then create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=TaskFlow AI <your_gmail@gmail.com>
